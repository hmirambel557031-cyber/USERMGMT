{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "Public/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/Public/index.php"
    },
    {
      "source": "/:path*",
      "destination": "/Public/:path*"
    }
  ]
}
